---
import { marked } from "marked";
import BaseLayout from "../layouts/BaseLayout.astro";
import DocShell from "../components/DocShell.astro";
import siteData from "../generated/site-data.json";

const page = siteData.pages.find((entry) => entry.path === siteData.homePagePath) ?? siteData.pages[0];
const stripMarkdown = (value) => (value || "")
  .replace(/```[\s\S]*?```/g, " ")
  .replace(/`[^`]+`/g, " ")
  .replace(/\[([^\]]+)\]\([^)]+\)/g, "$1")
  .replace(/<[^>]+>/g, " ")
  .replace(/[*_#>-]/g, " ")
  .replace(/\s+/g, " ")
  .trim();
const pageDescription = page.seoDescription || stripMarkdown(page.summaryMd).slice(0, 140) || "OpenClaw 文档五岁小孩都能听懂的中文解释版。";

const preparedPage = {
  ...page,
  summaryHtml: marked.parse(page.summaryMd || "这页的简要总结正在重新生成。"),
  explanationHtml: marked.parse(page.explanationMd || "这页的详细解释正在重新生成。")
};

const canonical = new URL("/", Astro.site).toString();
const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: "OpenClaw 中文解释版",
    url: Astro.site?.toString() || canonical,
    inLanguage: "zh-CN",
    description: "把 OpenClaw 英文文档讲成小朋友也能听懂的中文。"
  },
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    name: `${page.title} | OpenClaw 中文解释版`,
    url: canonical,
    description: pageDescription,
    inLanguage: "zh-CN"
  }
];
---

<BaseLayout title={`${page.title} | OpenClaw 中文解释版`} description={pageDescription} canonical={canonical} jsonLd={jsonLd}>
  <DocShell page={preparedPage} siteData={siteData} currentPath="/" />
</BaseLayout>
