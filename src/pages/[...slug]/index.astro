---
import { marked } from "marked";
import BaseLayout from "../../layouts/BaseLayout.astro";
import DocShell from "../../components/DocShell.astro";
import siteData from "../../generated/site-data.json";

const stripMarkdown = (value) => (value || "")
  .replace(/```[\s\S]*?```/g, " ")
  .replace(/`[^`]+`/g, " ")
  .replace(/\[([^\]]+)\]\([^)]+\)/g, "$1")
  .replace(/<[^>]+>/g, " ")
  .replace(/[*_#>-]/g, " ")
  .replace(/\s+/g, " ")
  .trim();

const breadcrumbName = (value) => value
  .replace(/^\//, "")
  .split("/")
  .filter(Boolean)
  .map((part) => part.replace(/-/g, " "))
  .join(" / ");

export function getStaticPaths() {
  return siteData.pages.flatMap((page) => {
    const paths = [page.path, ...(page.aliases ?? [])].filter((value) => value !== "/");
    return paths.map((pathname) => ({
      params: { slug: pathname.replace(/^\//, "") },
      props: {
        page,
        currentPath: pathname
      }
    }));
  });
}

const { page, currentPath } = Astro.props;

const preparedPage = {
  ...page,
  summaryHtml: marked.parse(page.summaryMd || "这页的简要总结正在重新生成。"),
  explanationHtml: marked.parse(page.explanationMd || "这页的详细解释正在重新生成。")
};

const canonical = new URL(currentPath, Astro.site).toString();
const pageDescription = page.seoDescription || stripMarkdown(page.summaryMd).slice(0, 140) || "OpenClaw 文档五岁小孩都能听懂的中文解释版。";
const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "TechArticle",
    headline: `${page.title} | OpenClaw 中文解释版`,
    description: pageDescription,
    url: canonical,
    inLanguage: "zh-CN",
    about: "OpenClaw documentation"
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "首页",
        item: new URL("/", Astro.site).toString()
      },
      {
        "@type": "ListItem",
        position: 2,
        name: page.sectionKey || breadcrumbName(currentPath) || page.title,
        item: canonical
      }
    ]
  }
];
---

<BaseLayout title={`${page.title} | OpenClaw 中文解释版`} description={pageDescription} canonical={canonical} jsonLd={jsonLd}>
  <DocShell page={preparedPage} siteData={siteData} currentPath={currentPath} />
</BaseLayout>
